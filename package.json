{
  "name": "lizy",
  "version": "0.1.0",
  "private": true,
  "description": "The data layer AI agents pay to use.",
  "scripts": {
    "build": "pnpm --filter @lizy/types build && pnpm --filter @lizy/mcp-server build",
    "start": "node apps/mcp-server/dist/index.js",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
